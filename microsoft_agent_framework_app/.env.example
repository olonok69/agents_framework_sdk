# Chat provider selection
# Supported values: foundry, openai, azure-openai, anthropic
MODEL_PROVIDER=foundry

# Foundry chat provider
FOUNDRY_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1
# Optional - only if you don't have a default tenant on `az login`
# AZURE_TENANT_ID=

# OpenAI chat provider
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1
# Optional fallback model key used by the OpenAI client
# OPENAI_MODEL=
# Optional custom base URL
# OPENAI_BASE_URL=

# Azure OpenAI chat provider (uses OpenAIChatClient with Azure routing)
AZURE_OPENAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com/
AZURE_OPENAI_CHAT_MODEL=gpt-4o
# Optional fallback model key used by the OpenAI client
# AZURE_OPENAI_MODEL=
# Optional if you authenticate with Azure identity (az login / managed identity)
AZURE_OPENAI_API_KEY=
# Optional API version override
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Anthropic chat provider
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5-20250929
# Optional base URL override
# ANTHROPIC_BASE_URL=

# Local MCP finance server (Phase 2)
MCP_FINANCE_SERVER_PATH=../adk_financial_mcp_server/server/main.py
# Path to the Python interpreter that has the finance server's deps installed.
# Easiest: point at the .venv created inside adk_financial_mcp_server.
MCP_FINANCE_PYTHON=../adk_financial_mcp_server/server/.venv/bin/python

# Judge provider selection for Phase 3 (evaluation) and Phase 4 (red-team)
# Supported values: azure-openai, openai
JUDGE_PROVIDER=azure-openai

# Azure OpenAI judge config (used when JUDGE_PROVIDER=azure-openai)
AZURE_DEPLOYMENT_NAME=gpt-4o
AZURE_API_KEY=
AZURE_ENDPOINT=https://<your-aoai-resource>.cognitiveservices.azure.com/
AZURE_API_VERSION=2024-12-01-preview

# OpenAI judge config (used when JUDGE_PROVIDER=openai)
# If omitted, evaluation/red-team fall back to OPENAI_API_KEY and OPENAI_CHAT_MODEL/OPENAI_MODEL.
JUDGE_OPENAI_API_KEY=
JUDGE_OPENAI_MODEL=
# Optional base URL for OpenAI-compatible endpoints.
# JUDGE_OPENAI_BASE_URL=https://api.openai.com/v1
# Optional organization.
# JUDGE_OPENAI_ORGANIZATION=
